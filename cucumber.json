{
    "default": {
        "requireModule": [
            "ts-node/register"
        ],
        "require": [
            "src/web/steps/*.ts",
            "src/utils/**/*.ts"
        ],
        "paths": [
            "tests/features/**/*.feature"
        ],
        "parallel": 2,
        "format": [
            "progress",
            "html:reports/cucumber-report.html"
        ],
        "formatOptions": {
            "snippetInterface": "async-await"
        }
    }
}